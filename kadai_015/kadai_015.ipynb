      "source": [
        "class Human:\n",
        "   #コンストラクタ\n",
        "   def __init__(self, name ,age):\n",
        "    #名前と年齢を定義する\n",
        "    self.name = name\n",
        "    self.age = age\n",
        "    #名前と年齢を標準出力するメソッド\n",
        "   def printinfo(self):\n",
        "       print(f\"名前は{self.name},年齢は{self.age}です\")\n",
        "\n",
        "#インスタンス化\n",
        "human = Human(\"太郎\",6)\n",
        "\n",
        "#\n",
        "human.printinfo()\n"
      ]
    }
  ]
